{
  "production": {
    "aws_region": "us-east-1",
    "django_settings": "RoadLabsAPI.settings.production",
    "profile_name": "default",
    "project_name": "kartado-general",
    "runtime": "python3.11",
    "memory_size": 1728,
    "ephemeral_storage": {
      "Size": 10240
    },
    "timeout_seconds": 900,
    "s3_bucket": "roadlabs-backend-production",
    "environment_variables": {
      "ZAPPA_ENVIRONMENT_NAME": "production"
    },
    "exclude": [
      ".git",
      "__pycache__",
      "venv"
    ],
    "events": [
      {
        "function": "apps.notifications.asynchronous.process_sqs_push_notification",
        "event_source": {
          "arn": "arn:aws:sqs:us-east-1:608592777334:kartado-push-notifications-production",
          "batch_size": 3,
          "maximum_batching_window_in_seconds": 5
        }
      },
      {
        "function": "apps.email_handler.asynchronous.send_queued_emails",
        "expression": "rate(1 minute)"
      },
      {
        "function": "apps.notifications.asynchronous.send_queued_push_notifications",
        "expression": "rate(1 minute)"
      },
      {
        "function": "apps.reportings.notifications.approval_step_report_email",
        "expression": "cron(30 7 ? * MON *)"
      },
      {
        "function": "apps.reportings.notifications.reporting_job_email",
        "expression": "cron(30 7 ? * MON *)"
      },
      {
        "function": "helpers.aws.send_aws_metrics",
        "expression": "rate(5 minutes)"
      },
      {
        "function": "apps.templates.notifications.call_email_mobile_sync_not_done",
        "expression": "rate(30 minutes)"
      },
      {
        "function": "apps.work_plans.asynchronous.process_job_async_batch",
        "expression": "rate(1 minute)"
      },
      {
        "function": "apps.work_plans.asynchronous.process_job_rep_in_rep_batches",
        "expression": "rate(1 minute)"
      },
      {
        "function": "apps.email_handler.asynchronous.delete_old_queued_emails",
        "expression": "cron(5 6 ? * * *)"
      },
      {
        "function": "apps.notifications.asynchronous.delete_old_queued_push",
        "expression": "cron(5 6 ? * * *)"
      },
      {
        "function": "apps.approval_flows.asynchronous.reporting_approval_weekly",
        "expression": "cron(0 21 ? * MON *)"
      },
      {
        "function": "apps.approval_flows.asynchronous.reporting_approval_daily",
        "expression": "cron(5 21 ? * * *)"
      },
      {
        "function": "apps.approval_flows.asynchronous.daily_report_approval_weekly",
        "expression": "cron(0 21 ? * MON *)"
      },
      {
        "function": "apps.approval_flows.asynchronous.daily_report_approval_daily",
        "expression": "cron(5 21 ? * * *)"
      },
      {
        "function": "apps.companies.create_instances_company_model",
        "expression": "cron(1 3 1 * ? *)"
      },
      {
        "function": "apps.work_plans.asynchronous.archive_completed_jobs",
        "expression": "cron(0 3 * * ? *)"
      },
      {
        "function": "apps.companies.asynchronous.cleanup_bim_disabled_companies",
        "expression": "cron(0 3 * * ? *)"
      },
      {
        "function": "apps.ml_predictions.asynchronous.fetch_ml_predictions_daily",
        "expression": "cron(0 9 * * ? *)"
      }
    ],
    "cloudwatch_log_level": "ERROR",
    "log_level": "DEBUG"
  },
