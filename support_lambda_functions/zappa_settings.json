{
  "production": {
    "app_function": "functions.fargate_proxy.wsgi.application",
    "aws_region": "us-east-1",
    "project_name": "kartado-fargate-proxy",
    "runtime": "python3.11",
    "timeout_seconds": 420,
    "memory_size": 256,
    "s3_bucket": "roadlabs-backend-production",
    "exclude": [".git", "__pycache__", "venv"],
    "environment_variables": {
      "ECS_CLUSTER_NAME": "ecs-general-cluster",
